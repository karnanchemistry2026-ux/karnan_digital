rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Only the specified admin can read or write to ANY document by default
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == "karnanchemistry2026@gmail.com";
    }
    
    // Specifically allow ALL authenticated users to READ the questions collection
    // but only the admin can WRITE (create, update, delete)
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email == "karnanchemistry2026@gmail.com";
    }
  }
}
